---
import Layout from '../layouts/Layout.astro';
import Card from '../components/Card.astro';
import Footer from '../components/Footer.astro';
import Hero from '../components/Hero.astro';
import Button from '../components/button.astro';
import MyProyects from '../components/MyProyects.astro';

---

<Layout title="Portfolio of Mario Hernández - Software & Web Developer">
	<main class="relod">
		<section class="section flex h-screen w-screen flex-col md:relative items-center justify-center">
			<Hero />
		</section>

		<section class="section md:px-40 border-2 border-slate-950 h-screen w-screen flex justify-center items-center">
			<Card title="About me" text="Software developer specialized in C#, Windows Forms, and .NET and passionate about the Astro framework with plugins using React.js or Vue.js that I have used in some of my projects" img="../playa.webp" pick="" href="/aboutme" />
		</section>
		
		<section class="section border-2 border-blue-500 md:pl-[740px] h-screen w-screen flex justify-center md:justify-end items-center">
			<Card title="Skills" text="As a developer, from writing clean C# code for desktop apps to working with modern tools like Astro, I'm always learning and improving." img="../bosque.webp" pick="" href="/skills" />
		</section>
		
		<section class="section border-2 border-green-500 md:pr-[740px] h-screen w-screen flex justify-center md:justify-start items-center">
			<Card title="Tecnologies" text="This is a list of the technologies I have used in my projects, from C# and .NET to Astro.js and Three.js, including Vue.js and React.js. " img="../montain.webp" pick="" href="/tecnologies" />
		</section>
		
		<section class="section border-2 border-purple-500 md:px-2 h-screen w-screen flex justify-center md:justify-end items-center ">
			<Card title="Connect" text="If you want to connect, feel free to reach out through the contact form or follow me on social media." img="../desiert.webp" pick="" href="/connect" />	
		</section>

		<section class="section mt-0 border-2 border-cyan-500 h-screen w-screen flex justify-center items-center">
			<MyProyects />
		</section>
		
		<section class="section h-screen border-2 border-red-500 w-screen text-center overflow-hidden translate-y-0">
			<Footer />
		</section>
		
	</main>
	<Button />
</Layout>

<style>
.section {
	transition: transform 10s ease-in-out;
}
</style>

